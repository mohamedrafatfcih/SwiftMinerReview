      "body" : {
        "content" : "guard let settings = app.getSystemSettings(), let hasSoundEnabled = settings[\"com.apple.sound.beep.feedback\"] as? Int, hasSoundEnabled == 1 else {\n      return\n    }\n    do {\n      self.audioPlayer = try AVAudioPlayer(contentsOf: URL(fileURLWithPath: \"/System/Library/LoginPlugins/BezelServices.loginPlugin/Contents/Resources/volume.aiff\"))\n      self.audioPlayer?.volume = 1\n      self.audioPlayer?.play()\n    } catch {\n      os_log(\"%{public}@\", type: .error, error.localizedDescription)\n    }"
      },
