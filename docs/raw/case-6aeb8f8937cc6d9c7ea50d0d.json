          ],
          "body" : {
            "content" : "switch type {\n    case .video: return noneVideoTrack\n    case .audio: return noneAudioTrack\n    case .sub: return noneSubTrack\n    case .secondSub: return noneSecondSubTrack\n    }"
          },
          "location_info" : {
