          "body": {
            "content": "switch event {\n        case .next(let value):\n            if !_running {\n                return\n            }\n            \n            do {\n                _running = try _parent._predicate(value)\n            } catch let e {\n                forwardOn(.error(e))\n                dispose()\n                return\n            }\n            \n            if _running {\n                forwardOn(.next(value))\n            } else {\n                forwardOn(.completed)\n                dispose()\n            }\n        case .error, .completed:\n            forwardOn(event)\n            dispose()\n        }"
          },
