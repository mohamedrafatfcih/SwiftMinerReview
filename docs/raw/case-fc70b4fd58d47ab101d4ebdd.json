            "content" : "func separator() -> NSBox {\n      let box = NSBox()\n      box.boxType = .separator\n      box.size(height: 1)\n      return box\n    }\n\n    let a = separator()\n    let b = separator()\n\n    let label = ui.hStack(\n      a,\n      ui.label(text, font: .boldSystemFont(ofSize: 12), isSecondary: true),\n      b,\n    )\n    a.widthAnchor.constraint(equalTo: b.widthAnchor).isActive = true\n    return label"
          },
