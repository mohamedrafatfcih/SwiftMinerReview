          "body": {
            "content": "var up = 0, total = 0\n        for m in machines {\n            total += 1\n            if m.online { up += 1 }\n        }\n        for h in hosts {\n            total += 1\n            if h.lastStatus?.lowercased() == \"up\" { up += 1 }\n        }\n        if total == 0 { return .tertiaryLabelColor }\n        if up == total { return .systemGreen }\n        if up == 0 { return .systemRed }\n        return .systemYellow"
          },
