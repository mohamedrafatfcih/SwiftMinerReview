        "content": "switch event {\n        case .next:\n            self._isEmpty = false\n            self.forwardOn(event)\n        case .error:\n            self.forwardOn(event)\n            self.dispose()\n        case .completed:\n            if self._isEmpty {\n                self.forwardOn(.next(self._default))\n            }\n            self.forwardOn(.completed)\n            self.dispose()\n        }"
