            "content" : "var newState: Bool = !self.isActive\n        if let state = state {\n            newState = state\n        }\n        \n        if self.isActive == newState {\n            return\n        }\n        \n        self.isActive = newState\n        \n        if !self.isActive {\n            self.disable()\n        } else {\n            self.enable()\n        }\n        \n        NotificationCenter.default.post(name: .toggleWidget, object: nil, userInfo: [\"module\": self.module])"
