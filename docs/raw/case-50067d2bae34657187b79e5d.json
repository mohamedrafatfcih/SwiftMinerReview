              "content" : "var buf = [UInt8]()\n        var trimming = true\n        for c in self.utf8 {\n            if trimming && c < 33 { continue }\n            trimming = false\n            buf.append(c)\n        }\n        \n        while let last = buf.last, last < 33 {\n            buf.removeLast()\n        }\n        \n        buf.append(0)\n        return String(cString: buf)"
