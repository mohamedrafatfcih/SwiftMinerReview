        "content": "assert(demand > 0)\n\n            guard let downstream = downstream.read({ $0 }) else { return }\n\n            self.downstream.write(nil)\n            responseHandler { response in\n                _ = downstream.receive(response)\n                downstream.receive(completion: .finished)\n            }.resume()"
