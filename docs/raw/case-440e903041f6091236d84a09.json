      "body": {
        "content": "let flags = event.modifierFlags.intersection(.deviceIndependentFlagsMask)\n    if flags == .command  {\n      switch event.charactersIgnoringModifiers! {\n      case \"f\":\n        // window!.makeFirstResponder(historySearchField)\n        break\n      case \"a\":\n        outlineView.selectAll(nil)\n      case \"\\r\":\n        playInNewWindowAction(nil)\n      case \"l\":\n        showInFinderAction(nil)\n      default:\n        break\n      }\n    } else {\n      let key = KeyCodeHelper.mpvKeyCode(from: event)\n      switch key {\n      case \"DEL\", \"BS\":\n        deleteAction(nil)\n      case \"ENTER\":\n        playAction(nil)\n      default:\n        break\n      }\n    }"
      },
