        "content": "let mounts = mounts.dedupe()\n        var result: [Filesystem] = []\n        result.reserveCapacity(mounts.count)\n        for tmpfs in mounts {\n            let fs = Filesystem.tmpfs(destination: tmpfs, options: [])\n            try validateMount(.filesystem(fs))\n            result.append(fs)\n        }\n        return result"
