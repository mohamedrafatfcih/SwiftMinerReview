          "body" : {
            "content" : "switch event {\n        case .next(let value):\n            if !self._running {\n                return\n            }\n            \n            do {\n                self._running = try self._parent._predicate(value)\n            } catch let e {\n                self.forwardOn(.error(e))\n                self.dispose()\n                return\n            }\n            \n            if self._running {\n                self.forwardOn(.next(value))\n            } else {\n                self.forwardOn(.completed)\n                self.dispose()\n            }\n        case .error, .completed:\n            self.forwardOn(event)\n            self.dispose()\n        }"
          },
