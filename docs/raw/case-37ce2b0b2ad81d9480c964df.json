          "body" : {
            "content" : "self.timeField.stringValue = newClock.formatted()\n        self.setDetails(newClock)\n        if let value = newClock.value {\n            self.clockView.setValue(value.convertToTimeZone(TimeZone(from: newClock.tz)))\n        }\n        self.clockView.display()"
