          "body" : {
            "content" : "switch event {\n        case .next(let value):\n            if !self.running {\n                do {\n                    self.running = try !self.parent.predicate(value)\n                } catch let e {\n                    self.forwardOn(.error(e))\n                    self.dispose()\n                    return\n                }\n            }\n\n            if self.running {\n                self.forwardOn(.next(value))\n            }\n        case .error, .completed:\n            self.forwardOn(event)\n            self.dispose()\n        }"
          },
