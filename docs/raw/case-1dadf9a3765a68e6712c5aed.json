            "throws_specifier": "throws"
          }
        },
        {
          "attributes": [],
          "body": {
            "content": "let client = ContainerClient()\n\n            let containers: [String]\n            if self.all {\n                containers = try await client.list().map { $0.id }\n            } else {\n                containers = containerIds\n            }\n\n            let opts = ContainerStopOptions(\n                timeoutInSeconds: self.time,\n                signal: self.signal\n            )\n            try await Self.stopContainers(\n                client: client,\n                containers: containers,\n                stopOptions: opts\n            )"
          },
          "location_info": {
            "file_path": "Sources/ContainerCommands/Container/ContainerStop.swift",
            "location": {
              "end_position": 2760,
              "start_position": 2144,
              "start_line": 56,
              "end_line": 77
            }
          },
          "modifiers": [
