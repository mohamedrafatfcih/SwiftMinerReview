          "specifiers_decl": {
            "async_specifier": "async",
            "description": "async throws",
            "throws_specifier": "throws"
          }
        },
        {
          "attributes": [],
          "body": {
            "content": "var errors: [any Error] = []\n            await withTaskGroup(of: (any Error)?.self) { group in\n                for container in containers {\n                    group.addTask {\n                        do {\n                            try await client.stop(id: container, opts: stopOptions)\n                            print(container)\n                            return nil\n                        } catch {\n                            return error\n                        }\n                    }\n                }\n\n                for await error in group {\n                    if let error {\n                        errors.append(error)\n                    }\n                }\n            }\n\n            if !errors.isEmpty {\n                throw AggregateError(errors)\n            }"
          },
