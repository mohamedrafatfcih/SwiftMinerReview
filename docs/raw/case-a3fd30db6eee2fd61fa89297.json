            "content" : "switch event {\n        case .next(let value):\n            do {\n                let satisfies = try self.predicate(value)\n                if satisfies {\n                    self.forwardOn(.next(value))\n                }\n            }\n            catch let e {\n                self.forwardOn(.error(e))\n                self.dispose()\n            }\n        case .completed, .error:\n            self.forwardOn(event)\n            self.dispose()\n        }"
