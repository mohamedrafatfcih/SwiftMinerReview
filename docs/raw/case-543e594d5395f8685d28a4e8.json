                "content": "assert(demand > 0)\n\n            guard let downstream = downstream else { return }\n\n            self.downstream = nil\n            streamHandler { stream in\n                _ = downstream.receive(stream)\n                if case .complete = stream.event {\n                    downstream.receive(completion: .finished)\n                }\n            }.resume()"
