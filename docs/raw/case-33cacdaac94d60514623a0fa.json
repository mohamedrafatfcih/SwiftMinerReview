          "body" : {
            "content" : "if containerIds.count == 0 && !all {\n                throw ContainerizationError(.invalidArgument, message: \"no containers specified and --all not supplied\")\n            }\n            if containerIds.count > 0 && all {\n                throw ContainerizationError(\n                    .invalidArgument, message: \"explicitly supplied container IDs conflict with the --all flag\")\n            }"
          },
          "location_info" : {
            "file_path" : "Sources/ContainerCommands/Container/ContainerStop.swift",
            "location" : {
              "end_position" : 2181,
              "start_position" : 1727
