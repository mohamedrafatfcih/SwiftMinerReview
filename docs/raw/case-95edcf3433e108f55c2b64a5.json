        "content" : "StreamOf<T>(bufferingPolicy: bufferingPolicy) { [unowned self] continuation in\n            yielder(continuation)\n            // Must come after serializers run in order to catch retry progress.\n            onFinish {\n                continuation.finish()\n            }\n        }"
