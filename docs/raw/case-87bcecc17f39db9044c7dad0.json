      "body": {
        "content": "TodoManager.refreshTodoScreen()\n        guard let screenWidth = TodoManager.todoScreen?.frame.width else { return value }\n\n        if toPixels {\n            return ((value * 0.01) * Float(screenWidth)).rounded()\n        } else {\n            return ((value / Float(screenWidth)) * 100).rounded()\n        }"
