          "body" : {
            "content" : "self.lock.lock(); defer { self.lock.unlock() }\n\n        do {\n            let observable = try self.performMap(element).asObservable()\n            self.hasLatest = true\n            self.latest = self.latest &+ 1\n            return (self.latest, observable)\n        }\n        catch let error {\n            self.forwardOn(.error(error))\n            self.dispose()\n        }\n\n        return nil"
          },
