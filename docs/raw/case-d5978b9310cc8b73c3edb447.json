          "body": {
            "content": "switch self {\n            case .brackets:\n                return \"\\(key)[]\"\n            case .noBrackets:\n                return key\n            case .indexInBrackets:\n                return \"\\(key)[\\(index)]\"\n            case let .custom(encoding): \n                return encoding(key, index)\n            }"
          },
