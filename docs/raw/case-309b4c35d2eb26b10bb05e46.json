            "content" : "switch event {\n        case .next(let value):\n            do {\n                _accumulation = try _parent._accumulator(_accumulation, value)\n            }\n            catch let e {\n                forwardOn(.error(e))\n                dispose()\n            }\n        case .error(let e):\n            forwardOn(.error(e))\n            dispose()\n        case .completed:\n            do {\n                let result = try _parent._mapResult(_accumulation)\n                forwardOn(.next(result))\n                forwardOn(.completed)\n                dispose()\n            }\n            catch let e {\n                forwardOn(.error(e))\n                dispose()\n            }\n        }"
