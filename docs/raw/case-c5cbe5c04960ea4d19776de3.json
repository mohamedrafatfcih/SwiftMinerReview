          "body" : {
            "content" : "switch self {\n            case .brackets: return \"\\(key)[]\"\n            case .noBrackets: return key\n            case .indexInBrackets: return \"\\(key)[\\(index)]\"\n            case let .custom(encoding): return encoding(key, index)\n            }"
