      "body" : {
        "content" : "var stopped = false\n        return self.primitiveSequence.asObservable().subscribe { event in\n            if stopped { return }\n            stopped = true\n            \n            switch event {\n            case .next(let element):\n                observer(.success(element))\n            case .error(let error):\n                observer(.error(error))\n            case .completed:\n                observer(.completed)\n            }\n        }"
      },
