          "body" : {
            "content" : "let subFont = player.mpv.getString(MPVOption.Subtitles.subFont) ??\n      NSLocalizedString(\"sidebar.font\", comment: \"\");\n    fontChooser.title = subFont\n\n    let currSubScale = player.mpv.getDouble(MPVOption.Subtitles.subScale).clamped(to: 0.1...10)\n    let displaySubScale = Utility.toDisplaySubScale(fromRealSubScale: currSubScale)\n    scaleSlider.doubleValue = displaySubScale + (displaySubScale > 0 ? -1 : 1)"
          },
          "location_info" : {
            "file_path" : "iina/SidebarSubtitlesPane.swift",
            "location" : {
              "end_position" : 15295,
              "start_position" : 14842
            }
          },
          "modifiers" : [
