          "body": {
            "content": "rootQueue.async {\n            let retry: () -> Void = {\n                guard !request.isCancelled else { return }\n\n                request.prepareForRetry()\n                self.perform(request)\n            }\n\n            if let retryDelay = timeDelay {\n                self.rootQueue.after(retryDelay) { retry() }\n            } else {\n                retry()\n            }\n        }"
