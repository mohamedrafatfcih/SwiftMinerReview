          "body": {
            "content": "let sanitized = value.isFinite ? value : 0\n        self.write {\n            if sanitized > 1 {\n                if sanitized > self.maxValue {\n                    self.maxValue = sanitized\n                }\n                self.value = sanitized / self.maxValue\n            } else {\n                self.value = sanitized\n            }\n        }\n        self.fadeOrDisplay()"
