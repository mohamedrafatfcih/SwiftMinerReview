            "content": "switch event {\n        case .next(let element):\n            do {\n                _accumulate = try _parent._accumulator(_accumulate, element)\n                forwardOn(.next(_accumulate))\n            }\n            catch let error {\n                forwardOn(.error(error))\n                dispose()\n            }\n        case .error(let error):\n            forwardOn(.error(error))\n            dispose()\n        case .completed:\n            forwardOn(.completed)\n            dispose()\n        }"
