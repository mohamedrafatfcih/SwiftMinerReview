          ]
        },
        {
          "attributes" : [

          ],
          "body" : {
            "content" : "if let helpURL = plugin.helpPageURL {\n      if helpURL.isFileURL {\n        webView.loadFileURL(helpURL, allowingReadAccessTo: plugin.root)\n      } else {\n        webView.load(URLRequest(url: helpURL))\n      }\n    } else {\n      webView.loadHTMLString(generateHTML(body: \"This plugin does not have a help page.\"), baseURL: nil)\n    }"
          },
