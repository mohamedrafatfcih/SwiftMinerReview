        },
        {
          "attributes" : [

          ],
          "body" : {
            "content" : "guard let prefURL = plugin.preferencesPageURL else {\n      webView.loadHTMLString(generateHTML(body: \"This plugin does not have a settings page.\"), baseURL: nil)\n      return\n    }\n    webView.loadFileURL(prefURL, allowingReadAccessTo: plugin.root)"
          },
          "location_info" : {
            "file_path" : "iina/SettingsPagePlugin.swift",
