            "content": "switch event {\n        case .next: break\n        case .error, .completed:\n            _self.dispose()\n        }\n        \n        if _parent._latest != _id {\n            return\n        }\n       \n        switch event {\n        case .next:\n            _parent.forwardOn(event)\n        case .error:\n            _parent.forwardOn(event)\n            _parent.dispose()\n        case .completed:\n            _parent._hasLatest = false\n            if _parent._stopped {\n                _parent.forwardOn(event)\n                _parent.dispose()\n            }\n        }"
          },
