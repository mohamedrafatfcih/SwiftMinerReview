            "content": "switch event {\n        case .next(let value):\n            \n            if self.remaining <= 0 {\n                self.forwardOn(.next(value))\n            }\n            else {\n                self.remaining -= 1\n            }\n        case .error:\n            self.forwardOn(event)\n            self.dispose()\n        case .completed:\n            self.forwardOn(event)\n            self.dispose()\n        }"
