        {
          "attributes": [],
          "body": {
            "content": "self.systemColorState = SColor.fromString(Store.shared.string(key: \"\\(self.name)_systemColor\", defaultValue: self.systemColorState.key))\n        self.userColorState = SColor.fromString(Store.shared.string(key: \"\\(self.name)_userColor\", defaultValue: self.userColorState.key))\n        self.idleColorState = SColor.fromString(Store.shared.string(key: \"\\(self.name)_idleColor\", defaultValue: self.idleColorState.key))\n        self.eCoresColorState = SColor.fromString(Store.shared.string(key: \"\\(self.name)_eCoresColor\", defaultValue: self.eCoresColorState.key))\n        self.pCoresColorState = SColor.fromString(Store.shared.string(key: \"\\(self.name)_pCoresColor\", defaultValue: self.pCoresColorState.key))\n        self.sCoresColorState = SColor.fromString(Store.shared.string(key: \"\\(self.name)_sCoresColor\", defaultValue: self.sCoresColorState.key))"
          },
