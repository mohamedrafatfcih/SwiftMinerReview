          "body": {
            "content": "switch event {\n        case .next(let value):\n            \n            if self._remaining > 0 {\n                self._remaining -= 1\n                \n                self.forwardOn(.next(value))\n            \n                if self._remaining == 0 {\n                    self.forwardOn(.completed)\n                    self.dispose()\n                }\n            }\n        case .error:\n            self.forwardOn(event)\n            self.dispose()\n        case .completed:\n            self.forwardOn(event)\n            self.dispose()\n        }"
          },
