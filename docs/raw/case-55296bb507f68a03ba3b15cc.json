          "attributes": [],
          "body": {
            "content": "let launchStart = Date()\n        let app = NSApplication.shared\n        let delegate = AppDelegate()\n        delegate.launchStart = launchStart\n        app.delegate = delegate\n        app.run()"
          },
          "location_info": {
