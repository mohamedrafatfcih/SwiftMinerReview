            },
            {
              "attributes": [],
              "body": {
                "content": "guard let documentView else { return }\n\n      let visibleWidth = contentView.bounds.width\n      let contentWidth = documentView.frame.width\n      let originX      = contentView.bounds.origin.x\n\n      guard contentWidth > visibleWidth else {\n        parent.indicator.isHidden = true\n        return\n      }\n\n      let eps: CGFloat = 1\n      let atLeading  = originX <= eps\n      let atTrailing = originX + visibleWidth >= contentWidth - eps\n\n      parent.indicatorDirection = atLeading ? .leading : atTrailing ? .trailing : .hidden"
              },
              "location_info": {
                "file_path": "iina/SidebarVideoPane.swift",
                "location": {
                  "end_position": 6398,
                  "start_position": 5823,
                  "start_line": 214,
                  "end_line": 233
                }
              },
              "modifiers": [
