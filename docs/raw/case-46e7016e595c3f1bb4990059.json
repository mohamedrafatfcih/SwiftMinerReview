          "body" : {
            "content" : "guard let mode = notification.userInfo?[\"mode\"] as? String, self.fansSyncState else {\n            return\n        }\n        \n        if mode == \"automatic\" {\n            self.setMode(.automatic)\n        } else if mode == \"forced\" {\n            self.setMode(.forced)\n        } else if mode == \"off\" {\n            let btn = NSButton()\n            btn.state = .on\n            btn.tag = 4\n            self.offMode(btn)\n        } else if mode == \"turbo\" {\n            let btn = NSButton()\n            btn.state = .on\n            btn.tag = 4\n            self.turboMode(btn)\n        }"
