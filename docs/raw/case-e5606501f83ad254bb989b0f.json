            "content" : "switch event {\n        case .next(let value):\n            do {\n                let key = try _parent._selector(value)\n                var areEqual = false\n                if let currentKey = _currentKey {\n                    areEqual = try _parent._comparer(currentKey, key)\n                }\n                \n                if areEqual {\n                    return\n                }\n                \n                _currentKey = key\n                \n                forwardOn(event)\n            }\n            catch let error {\n                forwardOn(.error(error))\n                dispose()\n            }\n        case .error, .completed:\n            forwardOn(event)\n            dispose()\n        }"
