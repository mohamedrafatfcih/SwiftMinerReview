          "body" : {
            "content" : "switch event {\n        case .next(let value):\n            self.elements.enqueue(value)\n            if self.elements.count > self.parent.count {\n                _ = self.elements.dequeue()\n            }\n        case .error:\n            self.forwardOn(event)\n            self.dispose()\n        case .completed:\n            for e in self.elements {\n                self.forwardOn(.next(e))\n            }\n            self.forwardOn(.completed)\n            self.dispose()\n        }"
          },
