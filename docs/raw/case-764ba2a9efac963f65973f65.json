  "rawRefactoring": {
    "category": "basic",
    "current_content": {
      "attributes": [],
      "body": {
        "content": "var current: ParsableCommand.Type = Application.self\n        for name in path {\n            guard let next = childSubcommands(of: current).first(where: { matches($0, name: name) }) else {\n                return nil\n            }\n            current = next\n        }\n        return current"
      },
