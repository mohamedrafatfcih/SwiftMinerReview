          "body" : {
            "content" : "switch event {\n        case .next(let element):\n            do {\n                try self.parent.accumulator(&self.accumulate, element)\n                self.forwardOn(.next(self.accumulate))\n            }\n            catch let error {\n                self.forwardOn(.error(error))\n                self.dispose()\n            }\n        case .error(let error):\n            self.forwardOn(.error(error))\n            self.dispose()\n        case .completed:\n            self.forwardOn(.completed)\n            self.dispose()\n        }"
          },
