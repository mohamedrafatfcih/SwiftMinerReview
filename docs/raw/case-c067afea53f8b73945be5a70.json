            "content" : "switch event {\n        case .next:\n            if self.element != nil {\n                self.forwardOn(.error(RxError.moreThanOneElement))\n                self.dispose()\n            }\n\n            self.element = event\n        case .error:\n            self.forwardOn(event)\n            self.dispose()\n        case .completed:\n            if let element = self.element {\n                self.forwardOn(element)\n                self.forwardOn(.completed)\n            }\n            else {\n                self.forwardOn(.error(RxError.noElements))\n            }\n            self.dispose()\n        }"
