        {
          "attributes": [],
          "body": {
            "content": "let volumePermissions: Bool = [KeyboardVolume.media.rawValue, KeyboardVolume.both.rawValue].contains(prefs.integer(forKey: PrefKey.keyboardVolume.rawValue))\n    let brigthnessPermissions: Bool = [KeyboardBrightness.media.rawValue, KeyboardBrightness.both.rawValue].contains(prefs.integer(forKey: PrefKey.keyboardBrightness.rawValue))\n    let permissionsRequired: Bool = volumePermissions || brigthnessPermissions\n    let enabled: Bool = !MediaKeyTapManager.readPrivileges(prompt: false) && permissionsRequired\n    self.permissionsButton.image = enabled ? nil : NSImage(named: \"onboarding_icon_checkmark\")"
          },
