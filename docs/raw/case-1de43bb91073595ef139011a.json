          "body": {
            "content": "switch event {\n        case .next:\n            var onNextWins = false\n            \n            self.lock.performLocked {\n                onNextWins = !self.switched\n                if onNextWins {\n                    self.id = self.id &+ 1\n                }\n            }\n            \n            if onNextWins {\n                self.forwardOn(event)\n                self.createTimeoutTimer()\n            }\n        case .error, .completed:\n            var onEventWins = false\n            \n            self.lock.performLocked {\n                onEventWins = !self.switched\n                if onEventWins {\n                    self.id = self.id &+ 1\n                }\n            }\n            \n            if onEventWins {\n                self.forwardOn(event)\n                self.dispose()\n            }\n        }"
