            "content" : "if isTransparant {\n      let shadow = NSShadow()\n      shadow.shadowColor = .black\n      shadow.shadowBlurRadius = 8\n      shadow.shadowOffset = .zero\n      titleTextField.shadow = shadow\n    } else {\n      titleTextField.shadow = nil\n    }"
