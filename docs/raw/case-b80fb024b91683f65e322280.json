      "functions": [
        {
          "attributes": [],
          "body": {
            "content": "var container = encoder.container(keyedBy: CodingKeys.self)\n        try container.encode(cpus, forKey: .cpus)\n        try container.encode(memory, forKey: .memory)\n        try container.encode(homeMount, forKey: .homeMount)\n        try container.encode(virtualization, forKey: .virtualization)\n        try container.encodeIfPresent(kernelPath?.string, forKey: .kernelPath)"
          },
          "location_info": {
