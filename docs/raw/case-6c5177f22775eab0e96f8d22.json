          "functions": [
            {
              "attributes": [],
              "body": {
                "content": "let parts = ref.components(separatedBy: \":\")\n            switch parts.count {\n            case 1:\n                return .local(ref)\n            case 2 where !parts[0].isEmpty && parts[1].starts(with: \"/\"):\n                return .container(id: parts[0], path: parts[1])\n            default:\n                throw ContainerizationError(.invalidArgument, message: \"invalid path given: \\(ref)\")\n            }"
              },
              "location_info": {
                "file_path": "Sources/ContainerCommands/Container/ContainerCopy.swift",
                "location": {
                  "end_position": 1626,
                  "start_position": 1128,
                  "start_line": 29,
                  "end_line": 41
                }
              },
              "modifiers": [
                "static"
              ],
              "name": "parsePathRef",
              "parameters": [
                {
                  "attributes": [],
                  "data_type": {
                    "is_optional": false,
                    "name": "String"
                  },
                  "is_variadic": false,
                  "label": "_",
                  "location_info": {
